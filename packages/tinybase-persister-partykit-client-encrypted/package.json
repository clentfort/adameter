{
	"name": "tinybase-persister-partykit-client-encrypted",
	"version": "0.0.1",
	"description": "Encrypted PartyKit client persister for TinyBase",
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/clentfort/adameter.git",
		"directory": "packages/tinybase-persister-partykit-client-encrypted"
	},
	"license": "MIT",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepack": "pnpm run build",
		"release": "semantic-release",
		"test": "vitest",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"peerDependencies": {
		"partysocket": ">=1 <2",
		"tinybase": ">=7 <9"
	},
	"devDependencies": {
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/github": "^12.0.0",
		"@semantic-release/npm": "^13.0.0",
		"@semantic-release/release-notes-generator": "^14.0.3",
		"@types/node": "^24.0.0",
		"jsdom": "^29.0.0",
		"partysocket": "1.1.16",
		"semantic-release": "^25.0.0",
		"tinybase": "^8.0.0",
		"typescript": "^6.0.0",
		"vitest": "^4.0.0"
	}
}
